{
  "name": "zoom-cli",
  "version": "0.1.0",
  "description": "Zoom meeting management CLI via Okta SSO",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "capture-cookies": "ts-node scripts/grab-cookies.ts",
    "auto-login": "ts-node scripts/auto-login.ts",
    "refresh-cookies": "ts-node scripts/refresh-cookies.ts",
    "sniff-api": "ts-node scripts/sniff-api.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:offline": "jest --testPathPattern=offline",
    "test:e2e": "jest --testPathPattern=e2e",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.16.0",
    "playwright": "^1.40.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}
